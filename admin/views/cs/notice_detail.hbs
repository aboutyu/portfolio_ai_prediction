<form name='notice_update' method='post' onSubmit='onSave(); return false;'>

<div class='row clearfix'>
  <div class='col-lg-12 col-md-12 col-sm-12 col-xs-12'>

      <div class='card'>

      <div class='body'>

        <table class='table table-bordered'>
          <tbody>
            <tr>
              <th class='text-center' width="15%">종류</th>
              <td width="35%">
                {{#if isFaq}}FAQ{{else}}공지사항{{/if}}
              </td>
              <th class='text-center' width="15%">sequence</th>
              <td width="35%">
                {{item.sequence}}
              </td>
            </tr>
            {{#if isFaq}}
            <tr>
              <th class='text-center'>FAQ종류</th>
              <td colspan="3">
                <div class="demo-radio-button">
                    {{#each faqKinds}}
                      <input 
                        name="faqKind" 
                        value="{{this.id}}" 
                        type="radio" 
                        id="faq_kind_{{this.id}}" 
                        class="with-gap radio-col-grey"
                        {{#if (eq ../item.faqKind this.id)}}checked{{/if}}>
                      <label for="faq_kind_{{this.id}}">{{this.faqName}}</label>
                    {{/each}}
                </div> 
              </td>
            </tr>
            {{/if}}
            <tr>
              <th class='text-center'>활성화여부</th>
              <td>
                <div class="demo-radio-button">
                    <input 
                      name="is_active" 
                      value="Y" 
                      type="radio" 
                      id="is_active_y" 
                      class="with-gap radio-col-grey"
                      {{eq item.isActivate true "checked" ""}}>
                    <label for="is_active_y">활성화</label>

                    <input 
                      name="is_active" 
                      value="N" 
                      type="radio" 
                      id="is_active_n" 
                      class="with-gap radio-col-grey"
                      {{eq item.isActivate false "checked" ""}}>
                    <label for="is_active_n">비활성화</label>
                </div> 
              </td>
              <th class='text-center'>생성일</th>
              <td>
                {{formatTimestamp item.createDate}}
              </td>
            </tr>
            <tr>
              <th class='text-center'>제목</th>
              <td colspan="3">
                <input 
                  type="text" 
                  name="title" 
                  id="title" 
                  style="width:100%;" 
                  class="form-control" 
                  placeholder="제목을 입력해주세요." 
                  value="{{item.title}}">
              </td>
            </tr>
            <tr>
              <th class='text-center'>내용</th>
              <td colspan='3'>
                <textarea name='content' id='ckeditor_content' rows='50' cols='80'>
                  {{item.content}}
                </textarea>
                <script>
                  CKEDITOR.replace('ckeditor_content');
                </script>

              </td>
            </tr>
            
            <tr>
              <th class='text-center'>메모</th>
              <td colspan='3'>
                <textarea 
                  name='memo' 
                  id='memo' 
                  rows='10' 
                  width='100%' 
                  class='form-control' 
                  placeholder='메모를 입력해주세요.'>{{item.memo}}</textarea>
              </td>
            </tr>
          </tbody>
        </table>

      </div>
    </div>
  </div> 
</div>

<input type="hidden" id="sequence" name="sequence" value="{{item.sequence}}">
<input type="hidden" id="page" name="page" value="{{page}}">
<input type="hidden" id="type" name="type" value="{{eq isFaq true "faq" "notice"}}">

<div class='row text-center' style='margin-bottom: 30px;'>
  <div class='btn-group'>
    <button type='submit' class='btn btn-danger dropdown-toggle waves-effect'>
      저장
    </button>

  </div>
  &nbsp;&nbsp;
  <div class='btn-group'>
    <button
      type='button'
      class='btn btn-info dropdown-toggle waves-effect'
      onClick='goList();'
    >
      목록
    </button>
  </div>
</form>

<script language='javascript'>
  function goList() { 
    const baseUrl = "/cs/{{#if isFaq}}faq{{else}}notice{{/if}}";
    
    // 2. URLSearchParams 객체 생성 및 기본 페이지 추가
    const params = new URLSearchParams();
    params.append("page", "{{page}}");

    // 3. 검색어(searchKeyword)가 있으면 추가
    const keyword = "{{searchDto.searchKeyword}}";
    if (keyword && keyword.trim() !== "") {
        params.append("searchKeyword", keyword);
    }

    // 4. 활성화 여부(isActivate)가 있으면 추가 (Y 또는 N)
    const isActivate = "{{searchDto.isActivate}}";
    // Handlebars 변수가 boolean true/false로 넘어올 경우를 대비해 변환 로직 포함
    if (isActivate === "true" || isActivate === "Y") {
        params.append("isActivate", "Y");
    } else if (isActivate === "false" || isActivate === "N") {
        params.append("isActivate", "N");
    }

    location.href = `${baseUrl}?${params.toString()}`;
   }
  
  function onSave() { 
    const form = document.notice_update;

    // 데이터 추출
    const content = CKEDITOR.instances.ckeditor_content.getData();
    const memo = form.memo.value;
    const title = form.title.value;
    const isActive = form.is_active.value;
    const sequence = form.sequence.value;
    const page = form.page.value;
    const type = form.type.value;

    if (!sequence || !page || !type) {
      alert('필수 데이터가 누락되었습니다.'); return false;
    }

    if (title === "") { 
      alert('제목을 입력해주세요'); return false; 
    } 

    if (content === "") { 
      alert('내용을 입력해주세요'); return false; 
    }

    if (!confirm('저장하시겠습니까?')) {
      return;
    }

    const payload = {
      sequence: sequence,
      page: Number(page),
      type: type,
      faqKind: form.faqKind ? form.faqKind.value : null,
      title: title,
      content: content,
      memo: memo,
      isActivate: isActive
    };

    fetch('/cs/notice/update', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(payload),
    })
    .then(response => {
      if (response.ok) {
        alert('저장되었습니다.');
        location.reload();
      } else {
        alert('저장 실패: 서버 오류가 발생했습니다.');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('네트워크 오류가 발생했습니다.');
    });
  }
</script>
