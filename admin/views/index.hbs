<html>

  <head>
    <meta charset='UTF-8' />
    <meta http-equiv='X-UA-Compatible' content='IE=Edge' />
    <meta
      content='width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no'
      name='viewport'
    />
    <title>{{service.serviceName}} 어드민</title>
    <!-- Favicon-->
    <link rel='icon' href='{{_p}}/favicon.ico' type='image/x-icon' />

    <!-- Google Fonts -->
    <link
      href='https://fonts.googleapis.com/css?family=Roboto:400,700&subset=latin,cyrillic-ext'
      rel='stylesheet'
      type='text/css'
    />
    <link
      href='https://fonts.googleapis.com/icon?family=Material+Icons'
      rel='stylesheet'
      type='text/css'
    />

    <!-- Bootstrap Core Css -->
    <link href='{{_p}}/plugins/bootstrap/css/bootstrap.css' rel='stylesheet' />

    <!-- Waves Effect Css -->
    <link href='{{_p}}/plugins/node-waves/waves.css' rel='stylesheet' />

    <!-- Animation Css -->
    <link href='{{_p}}/plugins/animate-css/animate.css' rel='stylesheet' />

    <!-- Custom Css -->
    <link href='{{_p}}/css/style.css' rel='stylesheet' />
  </head>

  <body class='login-page'>
    <div class='login-box'>
      <div class='logo'>
        <a href='javascript:void(0);'>어드민</a>
        <small>Admin for <b>{{service.serviceName}}</b> applications</small>
      </div>
      <div class='card'>
        <div class='body'>
          <form id='sign_in' method='POST' action='/login'>
            <div class='msg'>로그인을 해주세요.</div>
            <div class='input-group'>
              <span class='input-group-addon'>
                <i class='material-icons'>person</i>
              </span>
              <div class='form-line'>
                <input
                  type='text'
                  class='form-control'
                  name='userId'
                  value='admin'
                  placeholder='아이디를 입력해주세요.'
                  required
                  autofocus
                />
              </div>
            </div>
            <div class='input-group'>
              <span class='input-group-addon'>
                <i class='material-icons'>lock</i>
              </span>
              <div class='form-line'>
                <input
                  type='password'
                  class='form-control'
                  name='password'
                  value='admin'
                  placeholder='비밀번호를 입력해주세요.'
                  required
                />
              </div>
            </div>
            <div class='row'>
              <div class='col-xs-8 p-t-5'>
              </div>
              <div class='col-xs-4'>
                <button
                  class='btn btn-block bg-pink waves-effect'
                  type='submit'
                >로그인</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Jquery Core Js -->
    <script src='{{_p}}/plugins/jquery/jquery.min.js'></script>

    <!-- Bootstrap Core Js -->
    <script src='{{_p}}/plugins/bootstrap/js/bootstrap.js'></script>

    <!-- Waves Effect Plugin Js -->
    <script src='{{_p}}/plugins/node-waves/waves.js'></script>

    <!-- Validation Plugin Js -->
    <script src='{{_p}}/plugins/jquery-validation/jquery.validate.js'></script>

    <!-- Custom Js -->
    <script src='{{_p}}/js/admin.js'></script>
    <script src='{{_p}}/js/pages/examples/sign-in.js'></script>
  </body>

</html>