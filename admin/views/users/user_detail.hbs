<div class='row clearfix'>
  <div class='col-lg-12 col-md-12 col-sm-12 col-xs-12'>

      <div class='card'>

      <div class='body'>

        <div class='row text-right' style='margin-bottom: 30px; margin-right: 10px;'>
        <div class='btn-group'>
          <button type='submit' class='btn bg-brown dropdown-toggle waves-effect'>
            건강등록정보 보기
          </button>

        </div>
        &nbsp;&nbsp;
        <div class='btn-group'>
          <button type='submit' class='btn bg-blue dropdown-toggle waves-effect'>
            음식등록정보 보기
          </button>

        </div>
        </div>

        <table class='table table-bordered'>
          <tbody>
            <tr>
              <th class='text-center' width="15%">ID</th>
              <td width="35%">
                {{user.userId}}
              </td>
              <th class='text-center' width="15%">sequence</th>
              <td width="35%">
                {{user.sequence}}
              </td>
            </tr>
            <tr>
              <th class='text-center'>사용자명</th>
              <td>
                {{user.username}}
              </td>
              <th class='text-center'>리프레시토큰 등록여부</th>
              <td>
                {{#if user.refreshToken}}
                  <button
                  type='button'
                  class='btn btn-info dropdown-toggle waves-effect'
                  onClick='deleteRefreshToken({{user.sequence}}, {{page}});'
                >
                  삭제
                </button>
                {{else}}
                  미등록
                {{/if}}
              </td>
            </tr>
            <tr>
              <th class='text-center' rowspan="3">썸네일</th>
              <td rowspan="3">
                {{#if user.thumbnail}}
                  <img src="{{user.thumbnail}}" alt="User Thumbnail" style="max-width: 95px; max-height: 95px;">
                {{else}}
                  미등록
                {{/if}}
              </td>
              <th class='text-center'>필수약관 동일일</th>
              <td>
                {{formatTimestamp user.agreeRequiredTerms}}
              </td>
            </tr>

            <tr>
              <th class='text-center'>마지막로그인일</th>
              <td>
                {{formatTimestamp user.lastLogin}}
              </td>
            </tr>
            <tr>
              <th class='text-center'>가입일</th>
              <td>
                {{formatTimestamp user.createDate}}
              </td>
            </tr>
            <tr>
              <th class='text-center'>메모</th>
              <td colspan='3'>
                <textarea name='memo' id='ckeditor' rows='50' cols='80'>
                  {{user.memo}}
                </textarea>
                <script>
                  CKEDITOR.replace('ckeditor');
                </script>

              </td>
            </tr>
          </tbody>
        </table>

      </div>
    </div>
  </div> 
</div>

<div class='row text-center' style='margin-bottom: 30px;'>
  <div class='btn-group'>
    <button type='submit' class='btn btn-danger dropdown-toggle waves-effect' onClick='onClick();'>
      저장
    </button>

  </div>
  &nbsp;&nbsp;
  <div class='btn-group'>
    <button
      type='button'
      class='btn btn-info dropdown-toggle waves-effect'
      onClick='goList();'
    >
      목록
    </button>
  </div>

<div class='row clearfix' style='margin-top: 30px;'>
  <div class='col-lg-12 col-md-12 col-sm-12 col-xs-12'>
      <div class='card'>
      <div class='body'>

        <div class='table-responsive'>

          <table class='table table-bordered table-hover'>
            <thead>
              <tr>
                <th class='text-center'>디바이스타입</th>
                <th class='text-center'>디바이스이름</th>
                <th class='text-center'>디바이스모델</th>
                <th class='text-center'>디바이스토큰</th>
                <th class='text-center'>생성일</th>
                <th class='text-center'>삭제</th>
              </tr>
            </thead>
            <tbody>
              {{#each user.devices}}
              <tr 
                  {{#if this.isActivate}}
                  onclick="location.href='/users/detail?sequence={{this.sequence}}&page={{../page}}'"
                  style='cursor:pointer;'
                  {{/if}}
                  >
                <td class='text-center'>{{this.deviceType}}</td>
                <td class='text-center'>{{this.deviceName}}</td>
                <td class='text-center'>{{this.deviceModel}}</td>
                <td class='text-center'>{{this.deviceToken}}</td>
                <td class='text-center'>{{formatTimestamp this.createDate}}</td>
                <td class='text-center'>
                  <button
                    type='button'
                    class='btn btn-info dropdown-toggle waves-effect'
                    onClick='deleteDevice(this)'
                    data-token="{{this.deviceToken}}"
                    data-name="{{this.deviceName}}"
                    data-model="{{this.deviceModel}}"
                    data-type="{{this.deviceType}}"
                    data-date="{{this.createDate}}"
                  >
                    삭제
                  </button>
                </td> 
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        



      </div>
    </div>
  </div>
</div>

<script language='javascript'>
  function goList() { location.href = "/users?page={{page}}"; }
  function deleteRefreshToken(sequence, page) {
    // 사용자에게 한 번 더 확인 (실수 방지)
    if (!confirm('리프레시 토큰을 삭제하시겠습니까?')) {
      return;
    }

    fetch('/users/delete/refreshToken', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        sequence: Number(sequence),
        page: Number(page)
      }),
    })
    .then(response => {
      if (response.ok) {
        alert('삭제되었습니다.');
        location.reload();
      } else {
        alert('삭제 중 오류가 발생했습니다.');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('네트워크 오류가 발생했습니다.');
    });
  }
  function deleteDevice(btn) {
    if (!confirm('해당 디바이스 정보를 삭제하시겠습니까?')) {
      return;
    }

    // 버튼의 data 속성에서 값들을 가져옵니다.
    const bodyData = {
      deviceToken: btn.dataset.token,
      deviceName: btn.dataset.name,
      deviceModel: btn.dataset.model,
      deviceType: btn.dataset.type,
      createDate: new Date(btn.dataset.date),
    };

    fetch('/users/delete/device', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(bodyData),
    })
    .then(response => {
      if (response.ok) {
        alert('디바이스가 삭제되었습니다.');
        location.reload();
      } else {
        alert('삭제 실패: 서버 오류가 발생했습니다.');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('네트워크 오류가 발생했습니다.');
    });
  }

  function onSave(btn) { 
    if (admin_add.user_id.value === "") { 
      alert('ID를 입력해주세요'); return false; 
    } 
    return true; 
  }
</script>
