<!-- Bordered Table -->
<div class='row clearfix'>
  <div class='col-lg-12 col-md-12 col-sm-12 col-xs-12'>
    <div class='card'>
      <div class='header'>
        <form name="emp_search" method="get" href="/users">
            <input type="hidden" name="page" value="{{page}}">
            <table class="table table-bordered">
                <tr>
                    <th class="text-center" style="width:20%">삭제여부</th>
                    <td class="text-left">

                        <div class="demo-radio-button">
                            <input name="is_active" value="A" type="radio" id="is_active_a" class="with-gap radio-col-grey">
                            <label for="is_active_a">전체</label>

                            <input name="is_active" value="Y" type="radio" id="is_active_y" class="with-gap radio-col-grey">
                            <label for="is_active_y">활성화</label>

                            <input name="is_active" value="N" type="radio" id="is_active_n" class="with-gap radio-col-grey">
                            <label for="is_active_n">삭제</label>
                        </div> 
                    </td>
                </tr>
                <tr>
                    <th class="text-center" style="width:20%">검색어</th>
                    <td class="text-left">
                        <input type="text" name="search_keyword" id="search_keyword" style="width:100%;" class="form-control" placeholder="이름, 닉네임, 모바일번호를 기준으로 자연어 검색이 됩니다.">
                    </td>
                </tr>
            </table>

            <div class="row text-center" style="margin-bottom: 5px;">
                <div class="btn-group">
                    <button type="submit" class="btn btn-danger dropdown-toggle waves-effect">
                        검색
                    </button>
                </div>
            </div>
        </form>
      </div>

      <div class='body'>

        <div class='row'>
          <div class='col-sm-6 row-bottom'>
            검색개수 :
            {{total}}개
          </div>

        </div>

        <div class='table-responsive'>

          <table class='table table-bordered table-hover'>
            <thead>
              <tr>
                <th class='text-center'>No</th>
                <th class='text-center'>ID</th>
                <th class='text-center'>이름</th>
                <th class='text-center'>삭제여부</th>
                <th class='text-center'>생성일</th>
                <th class='text-center'>비고</th>
              </tr>
            </thead>
            <tbody>
              {{#each items}}
              <tr 
                  {{#if this.isActivate}}
                    style='cursor:pointer;'
                  {{/if}}
                  >
                <td class='text-center'>{{calculateTableNo ../total ../page @index}}</td>
                <td class='text-center'>{{this.userId}}</td>
                <td class='text-center'>{{this.userName}}</td>
                <td class='text-center'>
                  {{#if this.isActivate}}
                  {{else}}
                    삭제
                  {{/if}}
                </td>
                <td class='text-center'>{{formatTimestamp this.createTime}}</td> 
                <td class='text-center'>
                  {{#if this.isActivate}}
                    <div class="btn-group">
                      <button type="button" class="btn btn-danger dropdown-toggle waves-effect" onClick='onResetPassword({{this.sequence}}, {{../page}});'>
                          비밀번호 초기화
                      </button>
                    </div>
                    <div class="btn-group">
                      <button type="button" class="btn bg-grey dropdown-toggle waves-effect" onClick='onUpdate({{this.sequence}}, false, {{../page}});'>
                          삭제
                      </button>
                    </div>
                  {{else}}
                    <div class="btn-group">
                      <button type="button" class="btn bg-grey dropdown-toggle waves-effect" onClick='onUpdate({{this.sequence}}, true, {{../page}});'>
                          등록
                      </button>
                    </div>
                  {{/if}}
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <div class="row text-center">
          {{{pagination total page pageSize searchDto}}}
        </div>

      </div>
    </div>
  </div>
</div>

<script>
  function onUpdate(sequence, isActivate, page) {
    const payload = { sequence, page, isActivate };
    if (!payload || !payload.sequence) return;

    if (!confirm(!isActivate ? '삭제하시겠습니까?' : '등록하시겠습니까?')) return;
    fetch(isActivate ? '/users/admin-users/activate' : '/users/admin-users/delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    })
    .then(response => {
      if (response.ok) {
        alert(!isActivate ? '삭제되었습니다.' : '등록되었습니다.');
        window.location.reload();
      } else {
        alert(!isActivate ? '삭제 실패: 서버 응답 오류' : '등록 실패: 서버 응답 오류');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('네트워크 오류가 발생했습니다.');
    });
  }

  function onResetPassword(sequence, page) {
    const payload = { sequence, page };
    if (!payload || !payload.sequence) return;

    if (!confirm('비밀번호를 초기화하시겠습니까?')) return;
    fetch('/users/admin-users/reset-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    })
    .then(response => {
      if (response.ok) {
        alert('비밀번호가 초기화되었습니다.');
        window.location.reload();
      } else {
        alert('비밀번호 초기화 실패: 서버 응답 오류');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('네트워크 오류가 발생했습니다.');
    });
  }
</script>
<!-- #END# Bordered Table -->