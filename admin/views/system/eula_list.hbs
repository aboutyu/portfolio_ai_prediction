<!-- Bordered Table -->
<div class='row clearfix'>
  <div class='col-lg-12 col-md-12 col-sm-12 col-xs-12'>
    <div class='card'>

      <div class='body'>

        <div class='table-responsive'>

          <table class='table table-bordered table-hover'>
            <thead>
              <tr>
                <th class='text-center'>약관이름</th>
                <th class='text-center'>약관종류(코드)</th>
                <th class='text-center'>등록개수</th>
              </tr>
            </thead>
            <tbody>
              {{#each eulaList}}
              <tr 
                  onclick="location.href='/system/eula/detail?type={{this.type}}'"
                  style='cursor:pointer;'
                  >
                <td class='text-center'>{{this.termsName}}</td>
                <td class='text-center'>{{this.type}}</td>
                <td class="text-center">{{this.count}}</td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>
</div>
<!-- #END# Bordered Table -->